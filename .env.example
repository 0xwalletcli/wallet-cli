# Private keys (not needed if using WalletConnect)
EVM_PRIVATE_KEY=0x...             # Ethereum private key (never shared, stays local)
SOLANA_PRIVATE_KEY=...            # base58 encoded, needed for send/stake on Solana

# Optional — custom RPC URLs (public endpoints used by default)
EVM_RPC_URL=
BASE_RPC_URL=
SOLANA_RPC_URL=

# Optional — for transaction history (free key at https://etherscan.io/apis)
ETHERSCAN_API_KEY=

# Optional — alternative swap providers
UNISWAP_API_KEY=               # free key from https://developers.uniswap.org
LIFI_API_KEY=                  # free key from https://li.fi/api — increases rate limit (200 req/2hr → 200 req/min)

# Optional — WalletConnect (sign via MetaMask/Phantom instead of .env keys)
WC_PROJECT_ID=                 # free project ID from https://cloud.reown.com

# Optional — Spritz Finance (withdraw USDC to bank account)
SPRITZ_API_KEY=                # API key from https://app.spritz.finance
